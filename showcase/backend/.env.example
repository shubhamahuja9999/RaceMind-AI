# RaceMind AI Research Lab — backend environment variables

# Path where the model lives (or will be downloaded to).
# Local dev default points at the repo's checkpoint.
MODEL_PATH=../../data/checkpoints/ppo_1m/best.zip

# OPTIONAL: URL to download the model on startup if MODEL_PATH is missing.
# The model is git-ignored, so on a fresh cloud deploy set this to a public URL —
# e.g. attach best.zip to the GitHub release and use its asset URL:
# MODEL_URL=https://github.com/shubhamahuja9999/RaceMind-AI/releases/download/v1.0.0/best.zip
MODEL_URL=

# Directory where rendered MP4s are written and served from /videos.
VIDEO_DIR=./videos

# Max steps per demo episode (keeps inference snappy; full episode is 1000).
MAX_STEPS=600

# Comma-separated allowed CORS origins (the frontend URL). Use * for local dev.
CORS_ORIGINS=http://localhost:3000
