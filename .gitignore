# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# --- Virtual environments ---
.venv/
venv/
env/

# --- Notebooks ---
.ipynb_checkpoints/

# --- Generated data (keep the folders, ignore their contents) ---
data/telemetry/*
!data/telemetry/.gitkeep
data/recordings/*
!data/recordings/.gitkeep
data/videos/*
!data/videos/.gitkeep
data/plots/*
!data/plots/.gitkeep
data/evaluation/*
!data/evaluation/.gitkeep
data/models/*
!data/models/.gitkeep
data/checkpoints/*
!data/checkpoints/.gitkeep
data/experiments/

# --- Logs (keep the folder, ignore the log files) ---
logs/*
!logs/.gitkeep

# --- TensorBoard runs ---
runs/

# --- Research experiment artifacts ---
# Keep the small, human-readable reports (spec.*, comparison.*, evaluation.json,
# experiment_*.md) and the plot PNGs; ignore the heavy binaries so the repo stays
# lightweight and clonable.
research/experiments/*/checkpoints/
research/experiments/*/videos/
research/experiments/*/logs/
research/experiments/*/logs_resume/
research/reward_analysis/*/reward_log.csv

# --- Large binaries (models, videos) never belong in git ---
*.zip
*.mp4
*.tfevents.*

# --- OS / editor noise ---
.DS_Store
Thumbs.db
.idea/
.vscode/
